#!/usr/bin/env php
<?php

// Charger automatiquement le fichier .env
$dotenvFile = __DIR__ . '/.env';
if (file_exists($dotenvFile)) {
    $lines = file($dotenvFile, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);
    foreach ($lines as $line) {
        $line = trim($line);
        if (strpos($line, '#') === 0) continue; // ignorer les commentaires
        if (!strpos($line, '=')) continue;     // ignorer les lignes sans '='
        putenv($line); // définit la variable d'environnement
    }
}

// Lecture du fichier SQL
$sqlFile = __DIR__ . '/src/Database/database.sql';
if (!file_exists($sqlFile)) {
    echo "❌ Fichier SQL introuvable : $sqlFile\n";
    exit(1);
}
$sql = file_get_contents($sqlFile);

// Connexion à MySQL (sans base)
try {
    $host   = getenv('DB_HOST') ?: '127.0.0.1';
    $port   = getenv('DB_PORT') ?: 3306;
    $user   = getenv('DB_USER');
    $pass   = getenv('DB_PASS');
    $dbName = getenv('DB_NAME');

    if (!$dbName) {
        echo "❌ Erreur : variable d'environnement DB_NAME non définie.\n";
        exit(1);
    }

    // Connexion initiale sans base sélectionnée
    $pdo = new PDO("mysql:host=$host;port=$port", $user, $pass);
    $pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);

    // Créer la base si elle n'existe pas
    $pdo->exec("CREATE DATABASE IF NOT EXISTS `$dbName` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci");
    echo "✅ Base de données '$dbName' créée ou déjà existante.\n";

    // Se reconnecter directement sur la base
    $pdo = new PDO("mysql:host=$host;port=$port;dbname=$dbName", $user, $pass);
    $pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);

    // Exécuter les requêtes SQL
    $pdo->exec($sql);

    echo "✅ Migration terminée avec succès.\n";

} catch (PDOException $e) {
    echo "❌ Erreur lors de la migration : " . $e->getMessage() . "\n";
    exit(1);
}
